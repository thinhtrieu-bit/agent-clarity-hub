# Backend port
PORT=8787

# Shared secret OpenClaw must send on write requests:
# Authorization: Bearer <OPENCLAW_API_KEY>
OPENCLAW_API_KEY=[GENERATE-A-LONG-RANDOM-SECRET]

# Keep synthetic API simulation disabled in production.
# Set to "true" only for local demo/testing of /api/sync/activity.
ALLOW_SYNTHETIC_SYNC=false

# Frontend API (dashboard reads via Express API)
# In local dev this defaults to http://localhost:8787/api if unset.
VITE_API_BASE_URL=http://localhost:8787/api

# Optional: enables dashboard write actions (create/update) from UI.
# Must match backend OPENCLAW_API_KEY.
VITE_OPENCLAW_API_KEY=[SAME-AS-OPENCLAW_API_KEY]

# Optional SQLite fallback (used when SUPABASE_DB_URL is not set)
AGENT_DB_PATH=server/agent-activity.sqlite

# Supabase Postgres backend (recommended)
# Connection string template:
# postgresql://postgres:[YOUR-PASSWORD]@db.zvcyolyidfbskawtrkcm.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.zvcyolyidfbskawtrkcm.supabase.co:5432/postgres

# Optional split fields (for clarity/onboarding)
SUPABASE_DB_HOST=db.zvcyolyidfbskawtrkcm.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=[YOUR-PASSWORD]
